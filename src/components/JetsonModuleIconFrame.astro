---
/**
 * SoM image with optional corner badges (family top-left, memory bottom-right).
 * Parent matrix tab should use Tailwind `group` when `applyGroupDisabledTint` is true.
 */
interface Props {
	iconSrc?: string;
	iconBadgeFamily?: string;
	iconBadgeMemory?: string;
	applyGroupDisabledTint?: boolean;
}

const {
	iconSrc,
	iconBadgeFamily,
	iconBadgeMemory,
	applyGroupDisabledTint = true,
} = Astro.props;

const tint = applyGroupDisabledTint ? 'group-disabled:opacity-45 group-disabled:saturate-50' : '';
---

<div
	class:list={['relative h-16 w-16 sm:h-24 sm:w-24 shrink-0 box-border pointer-events-none', tint]}
	aria-hidden="true"
>
	{
		iconSrc ? (
			<div class="flex h-full w-full items-center justify-center overflow-hidden rounded-lg border-2 border-nvidia-gray-400 bg-white p-1 sm:p-1.5">
				<img
					src={iconSrc}
					alt=""
					class="max-h-full max-w-full object-contain"
					width="96"
					height="96"
					loading="lazy"
					decoding="async"
				/>
			</div>
		) : (
			<div class="flex h-full w-full items-center justify-center overflow-hidden rounded-lg border-2 border-dashed border-nvidia-gray-500 bg-gradient-to-br from-nvidia-gray-100 to-nvidia-gray-200">
				<span class="px-1 text-center text-xs font-bold leading-tight text-nvidia-gray-500">ISO</span>
			</div>
		)
	}
	{
		iconBadgeFamily && (
			<span
				class="absolute left-0 top-0 z-[2] max-w-[75%] truncate rounded-br-lg bg-nvidia-black px-2 py-1 text-[12px] font-bold leading-tight text-white shadow-md sm:max-w-[72%] sm:text-[14px] sm:leading-none"
			>
				{iconBadgeFamily}
			</span>
		)
	}
	{
		iconBadgeMemory && (
			<span
				class="absolute bottom-0 right-0 z-[2] max-w-[75%] truncate rounded-tl-lg bg-nvidia-green px-2 py-1 text-[12px] font-bold leading-tight tabular-nums text-nvidia-black shadow-md sm:max-w-[72%] sm:text-[14px] sm:leading-none"
			>
				{iconBadgeMemory}
			</span>
		)
	}
</div>
