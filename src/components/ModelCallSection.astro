---
import type { SupportedEngineEntry } from '../lib/inferenceCommands';
import { buildClientCallExamples, type ClientCallExample } from '../lib/modelClientExamples';

interface ClientCallFrontmatter {
	shell?: string;
	python?: string;
	intro?: string;
}

interface Props {
	engines: SupportedEngineEntry[];
	modelSlug: string;
	hfCheckpoint?: string;
	clientCall?: ClientCallFrontmatter | null;
}

const { engines, modelSlug, hfCheckpoint, clientCall } = Astro.props;

const fromFrontmatter: ClientCallExample[] = [];
const ccIntro = clientCall?.intro?.trim();
if (clientCall?.shell?.trim()) {
	fromFrontmatter.push({
		engineLabel: 'Shell',
		lang: 'shell',
		intro:
			'From model front matter: <code class="text-xs bg-nvidia-gray-100 px-1 rounded">client_call.shell</code>.',
		command: clientCall.shell.trim(),
	});
}
if (clientCall?.python?.trim()) {
	fromFrontmatter.push({
		engineLabel: 'Python',
		lang: 'python',
		intro:
			'From model front matter: <code class="text-xs bg-nvidia-gray-100 px-1 rounded">client_call.python</code>.',
		command: clientCall.python.trim(),
	});
}

const generated = buildClientCallExamples(engines, {
	modelId: modelSlug,
	hfCheckpoint,
});

const examples: ClientCallExample[] = [...fromFrontmatter, ...generated];

const hasExamples = examples.length > 0;
const anyJetsonHostPlaceholder = hasExamples && examples.some((ex) => ex.command.includes('JETSON_HOST'));

function exampleLang(ex: ClientCallExample): 'shell' | 'python' {
	return ex.lang === 'python' ? 'python' : 'shell';
}
const hasShellExamples = hasExamples && examples.some((ex) => exampleLang(ex) === 'shell');
const hasPythonExamples = hasExamples && examples.some((ex) => exampleLang(ex) === 'python');
const showCallLangTabs = hasShellExamples && hasPythonExamples;

function isFirstExampleOfLang(i: number): boolean {
	const lang = exampleLang(examples[i]);
	return !examples.slice(0, i).some((ex) => exampleLang(ex) === lang);
}
---

<section
	id="call-model"
	class="py-16 bg-white border-b border-nvidia-gray-200 scroll-mt-20"
	aria-labelledby="call-model-heading"
	data-model-slug={modelSlug}
>
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<h2 id="call-model-heading" class="text-3xl font-bold text-nvidia-black mb-2">
			Call the model
		</h2>
		<p class="text-sm text-nvidia-gray-600 max-w-3xl mb-8">
			Set connection parameters on the left, then use the examples on the right (this machine or another host on the
			network). When both are available, switch <strong>Shell</strong> or <strong>Python</strong> next to Copy command —
			<code class="text-xs bg-nvidia-gray-100 px-1 rounded">curl</code> vs the OpenAI SDK (
			<code class="text-xs bg-nvidia-gray-100 px-1 rounded">pip install openai</code>). Ports and model ids must match
			your running server.
		</p>

		{ccIntro && fromFrontmatter.length > 0 && (
			<p class="text-sm text-nvidia-gray-700 max-w-3xl mb-6" set:html={ccIntro} />
		)}

		{
			hasExamples ? (
				<div class="flex flex-col lg:flex-row gap-6 lg:gap-8 items-start">
					{
						anyJetsonHostPlaceholder && (
							<aside class="w-full lg:w-[min(100%,18rem)] xl:w-72 shrink-0 rounded-xl border border-nvidia-gray-200 bg-nvidia-gray-50/90 px-3 py-4 lg:px-4">
								<div class="flex flex-wrap items-center justify-between gap-2 mb-2">
									<h3 class="text-[10px] font-bold text-nvidia-gray-400 uppercase tracking-wider leading-tight">
										Parameters
									</h3>
									<button
										type="button"
										id="model-call-advanced-toggle"
										class="text-[11px] font-medium text-nvidia-green hover:text-nvidia-green/80 flex items-center gap-0.5 shrink-0"
										aria-expanded="true"
										aria-controls="model-call-advanced-body"
									>
										<span data-model-call-adv-toggle-text>Hide</span>
										<svg
											data-model-call-adv-toggle-icon
											class="w-3 h-3 transition-transform duration-200 shrink-0 rotate-180"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
											aria-hidden="true"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M19 9l-7 7-7-7"
											/>
										</svg>
									</button>
								</div>
								<div id="model-call-advanced-body" class="space-y-3 pt-1">
									<div>
										<label
											for="model-call-jetson-host"
											class="block text-xs font-medium text-nvidia-gray-700 mb-1"
										>
											Jetson host
										</label>
										<input
											id="model-call-jetson-host"
											type="text"
											value=""
											placeholder="e.g. localhost or 192.168.1.10"
											autocomplete="off"
											class="w-full bg-white border border-nvidia-gray-200 text-nvidia-black text-xs rounded-lg px-2.5 py-2 focus:ring-2 focus:ring-nvidia-green/20 focus:border-nvidia-green outline-none font-mono"
										/>
										<p class="text-[9px] text-nvidia-gray-500 mt-1.5 leading-snug">
											Substitutes{' '}
											<code class="text-[9px] bg-white border border-nvidia-gray-200 px-0.5 rounded">
												{'${JETSON_HOST}'}
											</code>{' '}
											in the command. Leave empty to keep that shell variable in the copied text.
										</p>
									</div>
								</div>
							</aside>
						)
					}
					<div class="min-w-0 flex-1 model-call-examples w-full">
						{
							showCallLangTabs && (
								<div class="flex flex-wrap items-center justify-between gap-3 mb-4 min-w-0">
									<div
										class="flex bg-white rounded-lg p-1 shadow-sm border border-nvidia-gray-200 shrink-0"
										role="tablist"
										aria-label="Example format"
									>
										<button
											type="button"
											role="tab"
											id="model-call-tab-shell"
											aria-selected="true"
											aria-controls="model-call-example-panels"
											data-model-call-lang-tab="shell"
											class="model-call-lang-tab px-4 py-1.5 rounded-md text-xs font-bold bg-nvidia-black text-nvidia-white shadow-sm transition-colors"
										>
											Shell
										</button>
										<button
											type="button"
											role="tab"
											id="model-call-tab-python"
											aria-selected="false"
											aria-controls="model-call-example-panels"
											data-model-call-lang-tab="python"
											class="model-call-lang-tab px-4 py-1.5 rounded-md text-xs font-bold text-gray-500 hover:text-nvidia-black transition-colors"
										>
											Python
										</button>
									</div>
									<button
										type="button"
										id="model-call-toolbar-copy"
										class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white border border-nvidia-gray-200 text-nvidia-gray-700 hover:border-nvidia-green hover:text-nvidia-green transition-all shadow-sm text-xs font-bold shrink-0"
									>
										<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"
											/>
										</svg>
										<span data-model-call-toolbar-copy-label>Copy command</span>
									</button>
								</div>
							)
						}
						<div id="model-call-example-panels" class="space-y-10">
							{examples.map((ex, i) => {
								const lang = exampleLang(ex);
								const hideForTab = showCallLangTabs && lang === 'python';
								return (
							<div
								class:list={['model-call-block', hideForTab && 'hidden']}
								data-call-engine={ex.engineLabel}
								data-call-example-lang={lang}
							>
								{
									ex.showEngineHeading !== false && (
										<h3 class="text-lg font-semibold text-nvidia-black mb-2">{ex.engineLabel}</h3>
									)
								}
								{ex.intro.trim() && <p class="text-sm text-nvidia-gray-600 mb-4" set:html={ex.intro} />}
								{
									!(showCallLangTabs && isFirstExampleOfLang(i)) && (
										<div class="flex flex-wrap items-center justify-end gap-2 mb-2">
											<button
												type="button"
												class="model-call-copy-btn flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white border border-nvidia-gray-200 text-nvidia-gray-700 hover:border-nvidia-green hover:text-nvidia-green transition-all shadow-sm text-xs font-bold"
												data-call-copy={i}
											>
												<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
													<path
														stroke-linecap="round"
														stroke-linejoin="round"
														stroke-width="2"
														d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"
													/>
												</svg>
												<span data-call-copy-label>Copy command</span>
											</button>
										</div>
									)
								}
								<div class="rounded-xl border border-gray-800 shadow-lg bg-[#0f172a] overflow-hidden">
									<pre
										class="text-sm font-mono text-slate-200 whitespace-pre-wrap break-words [overflow-wrap:anywhere] p-4 m-0"
									>
										<code
											class="model-call-command block w-full max-w-full whitespace-pre-wrap break-words [overflow-wrap:anywhere]"
											data-call-index={i}
											data-call-lang={ex.lang ?? 'shell'}
										>
											{ex.command}
										</code>
									</pre>
								</div>
							</div>
								);
							})}
						</div>
					</div>
				</div>
			) : (
				<p class="text-sm text-nvidia-gray-500 italic">
					A sample HTTP client command is not generated for this model&apos;s engine yet. Use your client
					(Open WebUI, curl, etc.) against the server you started above.
				</p>
			)
		}
	</div>
</section>

{
		hasExamples && (
		<script>
			import { highlightSyntax, shellDisplayAndCopy } from '../lib/commandSyntaxHighlight';
			import { trackCopyInferenceCommand } from '../lib/analyticsInference';

			function initModelCallSection() {
				const root = document.getElementById('call-model');
				if (!root || root.dataset.callInit === '1') return;
				root.dataset.callInit = '1';
				const pageModelSlug = root.dataset.modelSlug || 'unknown';
				const hostInput = document.getElementById('model-call-jetson-host') as HTMLInputElement | null;

				const callAdvToggle = document.getElementById('model-call-advanced-toggle');
				const callAdvBody = document.getElementById('model-call-advanced-body');
				const callAdvToggleText = callAdvToggle?.querySelector('[data-model-call-adv-toggle-text]');
				const callAdvToggleIcon = callAdvToggle?.querySelector('[data-model-call-adv-toggle-icon]');
				callAdvToggle?.addEventListener('click', () => {
					if (!callAdvBody || !callAdvToggle) return;
					callAdvBody.classList.toggle('hidden');
					const open = !callAdvBody.classList.contains('hidden');
					callAdvToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
					if (callAdvToggleText) callAdvToggleText.textContent = open ? 'Hide' : 'Show';
					callAdvToggleIcon?.classList.toggle('rotate-180', open);
				});

				const langTabs = root.querySelectorAll<HTMLButtonElement>('[data-model-call-lang-tab]');
				function setCallLangTab(lang: 'shell' | 'python') {
					root.querySelectorAll<HTMLElement>('.model-call-block').forEach((el) => {
						const blockLang = el.getAttribute('data-call-example-lang');
						if (blockLang === lang) el.classList.remove('hidden');
						else el.classList.add('hidden');
					});
					langTabs.forEach((btn) => {
						const l = btn.getAttribute('data-model-call-lang-tab');
						const active = l === lang;
						btn.setAttribute('aria-selected', active ? 'true' : 'false');
						const base =
							'model-call-lang-tab px-4 py-1.5 rounded-md text-xs font-bold transition-colors';
						btn.className =
							base +
							(active
								? ' bg-nvidia-black text-nvidia-white shadow-sm'
								: ' text-gray-500 hover:text-nvidia-black');
					});
				}
				langTabs.forEach((btn) => {
					btn.addEventListener('click', () => {
						const l = btn.getAttribute('data-model-call-lang-tab');
						if (l === 'shell' || l === 'python') setCallLangTab(l);
					});
				});

				function renderAllCallCommands() {
					root.querySelectorAll<HTMLElement>('.model-call-command').forEach((codeEl) => {
						if (!codeEl.dataset.callTemplate) {
							codeEl.dataset.callTemplate = codeEl.textContent?.trim() || '';
						}
						const template = codeEl.dataset.callTemplate || '';
						if (!template) return;
						let raw = template;
						if (hostInput) {
							const h = hostInput.value.trim();
							if (h !== '') {
								raw = template
									.replace(/\$\{JETSON_HOST\}/g, h)
									.replace(/JETSON_HOST/g, h);
							}
						}
						const lang = codeEl.dataset.callLang === 'python' ? 'python' : 'shell';
						if (lang === 'shell') {
							const { display, copy } = shellDisplayAndCopy(raw);
							codeEl.dataset.copyPlain = copy;
							codeEl.innerHTML = highlightSyntax(display, 'shell');
						} else {
							codeEl.dataset.copyPlain = raw;
							codeEl.innerHTML = highlightSyntax(raw, 'python');
						}
					});
				}

				renderAllCallCommands();
				hostInput?.addEventListener('input', () => renderAllCallCommands());

				const toolbarCopy = document.getElementById('model-call-toolbar-copy');
				const toolbarCopyLabel = toolbarCopy?.querySelector<HTMLElement>(
					'[data-model-call-toolbar-copy-label]',
				);
				toolbarCopy?.addEventListener('click', () => {
					const firstBlock = root.querySelector<HTMLElement>('.model-call-block:not(.hidden)');
					const codeEl = firstBlock?.querySelector<HTMLElement>('.model-call-command');
					const copyText = codeEl?.dataset.copyPlain?.trim() || '';
					if (!copyText) return;
					const engineLabel = firstBlock?.getAttribute('data-call-engine') || '';

					void navigator.clipboard.writeText(copyText).then(() => {
						trackCopyInferenceCommand({
							source: 'model_page_client_call',
							model_id: pageModelSlug,
							module_id: '',
							module_label: '',
							inference_engine: engineLabel,
						});
					});

					if (toolbarCopyLabel) {
						const prev = toolbarCopyLabel.textContent || '';
						toolbarCopyLabel.textContent = 'Copied';
						setTimeout(() => {
							toolbarCopyLabel.textContent = prev;
						}, 1200);
					}
				});

				root.querySelectorAll<HTMLButtonElement>('.model-call-copy-btn').forEach((btn) => {
					btn.addEventListener('click', () => {
						const idx = btn.getAttribute('data-call-copy');
						const codeEl =
							idx != null
								? root.querySelector<HTMLElement>(`.model-call-command[data-call-index="${idx}"]`)
								: null;
						const copyText = codeEl?.dataset.copyPlain?.trim() || '';
						if (!copyText) return;

						const block = btn.closest('.model-call-block');
						const engineLabel = block?.getAttribute('data-call-engine') || '';

						void navigator.clipboard.writeText(copyText).then(() => {
							trackCopyInferenceCommand({
								source: 'model_page_client_call',
								model_id: pageModelSlug,
								module_id: '',
								module_label: '',
								inference_engine: engineLabel,
							});
						});

						const label = btn.querySelector('[data-call-copy-label]');
						if (label) {
							const prev = label.textContent || '';
							label.textContent = 'Copied';
							setTimeout(() => {
								label.textContent = prev;
							}, 1200);
						}
					});
				});
			}

			initModelCallSection();
			document.addEventListener('astro:page-load', initModelCallSection);
		</script>
	)
}
