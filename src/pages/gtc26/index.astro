---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="GTC 2026 Workshop - Generative AI on Jetson Thor" description="100-minute hands-on workshop at GTC 2026: Master Generative AI on NVIDIA Jetson Thor and AGX platforms.">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-emerald-950 to-slate-900 text-white py-20 overflow-hidden">
    <!-- Animated background elements - more green -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 -right-20 w-96 h-96 bg-nvidia-green/30 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 -left-20 w-80 h-80 bg-nvidia-green/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-nvidia-green/10 rounded-full blur-3xl"></div>
    </div>
    
    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-15" style="background-image: linear-gradient(rgba(118,185,0,0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(118,185,0,0.15) 1px, transparent 1px); background-size: 50px 50px;"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <!-- Text Content -->
        <div class="flex-1 text-center lg:text-left">
          <!-- GTC Badge - Bigger -->
          <div class="inline-flex items-center gap-3 bg-nvidia-green/20 backdrop-blur-sm border border-nvidia-green/40 rounded-full px-6 py-3 mb-8">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-nvidia-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-nvidia-green"></span>
            </span>
            <span class="text-xl font-bold text-nvidia-green">GTC 2026</span>
            <span class="text-lg text-nvidia-green/80">• 100-Minute Workshop</span>
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-nvidia-green to-white">
              Deploy and Optimize LLMs and VLMs
            </span>
            <br />
            <span class="text-white">on NVIDIA Jetson Thor</span>
          </h1>
          
          <p class="text-lg text-slate-300 max-w-xl">
            The definitive platform for Physical AI — perception, reasoning, and action at the edge.
          </p>
        </div>
        
        <!-- Thor Image -->
        <div class="flex-1 flex justify-center lg:justify-end">
          <img 
            src="/images/hero/isometric_jat-devkit.png" 
            alt="NVIDIA Jetson Thor Developer Kit" 
            class="w-full max-w-md lg:max-w-lg drop-shadow-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Overview -->
  <section class="py-20 bg-slate-900 border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Powered by Jetson</h2>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">The next generation of edge AI platforms for generative AI workloads</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Jetson Thor Card -->
        <div class="group relative bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl p-8 border border-slate-700 hover:border-nvidia-green/50 transition-all duration-300 overflow-hidden">
          <div class="absolute top-0 right-0 w-40 h-40 bg-nvidia-green/10 rounded-full blur-3xl group-hover:bg-nvidia-green/20 transition-all"></div>
          <div class="relative">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-nvidia-green/10 rounded-xl flex items-center justify-center group-hover:bg-nvidia-green/20 transition-colors">
                <svg class="w-8 h-8 text-nvidia-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <span class="text-xs font-medium text-nvidia-green uppercase tracking-wider">New</span>
                <h3 class="text-2xl font-bold text-white">Jetson Thor</h3>
              </div>
            </div>
            
            
            
            <ul class="space-y-3 text-slate-400">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-nvidia-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>2560-core Blackwell GPU</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-nvidia-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>128GB Unified Memory</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-nvidia-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Up to 2,070 TOPS (FP4) AI Performance</span>
              </li>
            </ul>
          </div>
        </div>
        
        <!-- Jetson AGX Orin Card -->
        <div class="group relative bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl p-8 border border-slate-700 hover:border-purple-500/50 transition-all duration-300 overflow-hidden">
          <div class="absolute top-0 right-0 w-40 h-40 bg-purple-500/10 rounded-full blur-3xl group-hover:bg-purple-500/20 transition-all"></div>
          <div class="relative">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-purple-500/10 rounded-xl flex items-center justify-center group-hover:bg-purple-500/20 transition-colors">
                <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                </svg>
              </div>
              <div>
                <span class="text-xs font-medium text-purple-400 uppercase tracking-wider">Production Ready</span>
                <h3 class="text-2xl font-bold text-white">Jetson AGX Orin</h3>
              </div>
            </div>
            
            
            
            <ul class="space-y-3 text-slate-400">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-purple-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>2048-core Ampere GPU</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-purple-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>32GB / 64GB Unified Memory</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-purple-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Up to 275 TOPS AI Performance</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Workshop Contents -->
  <section id="workshop-labs" class="py-20 bg-slate-900 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Workshop Tutorials</h2>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">Setup and three hands-on labs to master generative AI on Jetson Thor</p>
      </div>
      
      <div class="space-y-6">
        <!-- Setup -->
        <a href="/gtc26/setup" class="group block bg-gradient-to-r from-slate-800 to-slate-800/50 rounded-2xl p-6 border border-slate-700 hover:border-blue-500/50 transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex-shrink-0">
              <div class="w-14 h-14 bg-blue-500/10 rounded-xl flex items-center justify-center group-hover:bg-blue-500/20 transition-colors">
                <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-medium text-blue-400 bg-blue-500/10 px-2 py-1 rounded">~5 min</span>
                <span class="text-xs font-medium text-amber-400 bg-amber-500/10 px-2 py-1 rounded">Required</span>
              </div>
              <h3 class="text-xl font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">
                Setup Jetson
              </h3>
              <p class="text-slate-400 text-sm">
                Find your device IP address and SSH into your Jetson Thor. Quick 5-minute setup.
              </p>
            </div>
            <div class="flex-shrink-0">
              <svg class="w-6 h-6 text-slate-600 group-hover:text-blue-400 group-hover:translate-x-2 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- 1. Introduction to AI microservice on Jetson -->
        <a href="/gtc26/intro-ai-microservice" class="group block bg-gradient-to-r from-slate-800 to-slate-800/50 rounded-2xl p-8 border border-slate-700 hover:border-nvidia-green/50 transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex-shrink-0">
              <div class="w-16 h-16 bg-nvidia-green/10 rounded-xl flex items-center justify-center text-3xl font-bold text-nvidia-green group-hover:bg-nvidia-green/20 transition-colors">
                1
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-medium text-nvidia-green bg-nvidia-green/10 px-2 py-1 rounded">~20 min</span>
                <span class="text-xs font-medium text-purple-400 bg-purple-500/10 px-2 py-1 rounded">Hands-On</span>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-nvidia-green transition-colors">
                Understanding LLMs and AI Microservices
              </h3>
              <p class="text-slate-400">
                Learn how to run and integrate AI microservices on NVIDIA Jetson for edge deployment.
              </p>
            </div>
            <div class="flex-shrink-0">
              <svg class="w-8 h-8 text-slate-600 group-hover:text-nvidia-green group-hover:translate-x-2 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- 2. Discover the capability of Vision AI: Live VLM WebUI -->
        <a href="/gtc26/vision-ai-live-vlm-webui" class="group block bg-gradient-to-r from-slate-800 to-slate-800/50 rounded-2xl p-8 border border-slate-700 hover:border-nvidia-green/50 transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex-shrink-0">
              <div class="w-16 h-16 bg-nvidia-green/10 rounded-xl flex items-center justify-center text-3xl font-bold text-nvidia-green group-hover:bg-nvidia-green/20 transition-colors">
                2
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-medium text-nvidia-green bg-nvidia-green/10 px-2 py-1 rounded">~20 min</span>
                <span class="text-xs font-medium text-amber-400 bg-amber-500/10 px-2 py-1 rounded">Hands-On</span>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-nvidia-green transition-colors">
                Understanding VLMs
              </h3>
              <p class="text-slate-400">
                Explore real-time vision AI with the Live VLM WebUI on Jetson.
              </p>
            </div>
            <div class="flex-shrink-0">
              <svg class="w-8 h-8 text-slate-600 group-hover:text-nvidia-green group-hover:translate-x-2 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- 3. Explore speech AI in voice pipeline: Multi-modal AI Studio -->
        <a href="/gtc26/conversation-ai-multi-modal-ai-studio" class="group block bg-gradient-to-r from-slate-800 to-slate-800/50 rounded-2xl p-8 border border-slate-700 hover:border-nvidia-green/50 transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex-shrink-0">
              <div class="w-16 h-16 bg-nvidia-green/10 rounded-xl flex items-center justify-center text-3xl font-bold text-nvidia-green group-hover:bg-nvidia-green/20 transition-colors">
                3
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-medium text-nvidia-green bg-nvidia-green/10 px-2 py-1 rounded">~20 min</span>
                <span class="text-xs font-medium text-amber-400 bg-amber-500/10 px-2 py-1 rounded">Hands-On</span>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-nvidia-green transition-colors">
                Voice + Vision with Multimodal AI Studio
              </h3>
              <p class="text-slate-400">
                Build and explore speech AI in voice pipelines with Multi-modal AI Studio on Jetson.
              </p>
            </div>
            <div class="flex-shrink-0">
              <svg class="w-8 h-8 text-slate-600 group-hover:text-nvidia-green group-hover:translate-x-2 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 0.2;
    }
    50% {
      opacity: 0.3;
    }
  }
  
  .animate-pulse {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>

