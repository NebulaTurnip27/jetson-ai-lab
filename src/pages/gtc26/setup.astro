---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Setup: Connect to Jetson Thor | GTC 2026" description="Quick setup guide to SSH into your Jetson Thor Developer Kit.">
  <!-- Hero Section -->
  <div class="bg-slate-900 text-white border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <div class="max-w-3xl">
        <div class="flex items-center gap-4 mb-6 text-sm">
          <a href="/gtc26" class="text-nvidia-green hover:text-white transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            GTC 2026 Workshop
          </a>
          <span class="text-slate-500">•</span>
          <span class="text-slate-400">Setup</span>
        </div>
        
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="text-xs font-medium text-nvidia-green bg-nvidia-green/10 px-2 py-1 rounded">~5 min</span>
          <span class="text-xs font-medium text-blue-400 bg-blue-500/10 px-2 py-1 rounded">Required</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight">
          Setup Your Jetson Thor Dev Kit
        </h1>
        
        <p class="text-xl text-slate-300 leading-relaxed">
          Connect to your Jetson Thor via SSH and get ready for the workshop.
        </p>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="lg:grid lg:grid-cols-12 lg:gap-12">
      <!-- Sidebar -->
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-8">
          <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-4">On this page</h3>
          <nav class="space-y-1">
            <a href="#about" class="block py-1.5 text-sm text-slate-600 hover:text-nvidia-green hover:pl-1 transition-all duration-200 border-l-2 border-transparent hover:border-nvidia-green pl-3 -ml-3">About the System</a>
            <a href="#find-ip" class="block py-1.5 text-sm text-slate-600 hover:text-nvidia-green hover:pl-1 transition-all duration-200 border-l-2 border-transparent hover:border-nvidia-green pl-3 -ml-3">Find Your IP Address</a>
            <a href="#ssh" class="block py-1.5 text-sm text-slate-600 hover:text-nvidia-green hover:pl-1 transition-all duration-200 border-l-2 border-transparent hover:border-nvidia-green pl-3 -ml-3">Connect via SSH</a>
            <a href="#verify" class="block py-1.5 text-sm text-slate-600 hover:text-nvidia-green hover:pl-1 transition-all duration-200 border-l-2 border-transparent hover:border-nvidia-green pl-3 -ml-3">Verify Connection</a>
          </nav>
          
          <div class="mt-8 pt-8 border-t border-slate-200">
            <a href="/gtc26/intro-genai" class="flex items-center gap-2 text-sm text-nvidia-green font-medium hover:underline">
              Next: Lab 1 - Intro to GenAI
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="lg:col-span-9">
        <div class="prose prose-slate prose-lg max-w-none
          prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-slate-900
          prose-p:text-slate-600 prose-p:leading-relaxed
          prose-a:text-nvidia-green prose-a:no-underline hover:prose-a:underline
          prose-strong:text-slate-900 prose-strong:font-bold
          prose-code:text-slate-800 prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none prose-code:font-medium
          prose-pre:bg-slate-900 prose-pre:shadow-lg prose-pre:rounded-xl prose-pre:border prose-pre:border-slate-800
          [&_pre_code]:bg-transparent [&_pre_code]:text-slate-200 [&_pre_code]:p-0
          prose-img:rounded-xl prose-img:shadow-md">
          
          <h2 id="about">📋 About the System</h2>
          
          <p>Your Jetson Thor Developer Kit runs <strong>L4T (Linux for Tegra)</strong> — NVIDIA's customized Ubuntu-based Linux distribution optimized for Jetson platforms.</p>
          
          <div class="not-prose my-6">
            <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
              <h4 class="font-bold text-slate-900 mb-3">L4T Key Features</h4>
              <ul class="space-y-2 text-slate-600">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-nvidia-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>Ubuntu 22.04 base with NVIDIA drivers pre-installed</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-nvidia-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>CUDA, cuDNN, and TensorRT ready to use</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-nvidia-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>Docker with NVIDIA runtime for containerized AI workloads</span>
                </li>
              </ul>
            </div>
          </div>
          
          <hr />
          
          <h2 id="find-ip">🔍 Step 1: Find Your IP Address</h2>
          
          <p>Each Jetson Thor at your workstation has a <strong>note card</strong> with its IP address.</p>
          
          <div class="not-prose my-6">
            <div class="bg-nvidia-green/5 border-2 border-nvidia-green/30 rounded-xl p-6">
              <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-nvidia-green/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-8 h-8 text-nvidia-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 text-lg mb-1">Check Your Note Card</h4>
                  <p class="text-slate-600 m-0">Look for the note card at your workstation. It contains your device's IP address (e.g., <code class="text-nvidia-green bg-nvidia-green/10 px-2 py-0.5 rounded">192.168.1.xxx</code>)</p>
                </div>
              </div>
            </div>
          </div>
          
          <hr />
          
          <h2 id="ssh">🔌 Step 2: Connect via SSH</h2>
          
          <p>Open a terminal on your laptop and connect to your Jetson Thor:</p>
          
          <pre><code class="language-bash">ssh nvidia@YOUR_IP_ADDRESS</code></pre>
          
          <p>Replace <code>YOUR_IP_ADDRESS</code> with the IP from your note card.</p>
          
          <div class="not-prose my-6">
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
              <div class="flex items-start gap-3">
                <span class="text-xl">🔑</span>
                <div>
                  <h4 class="font-bold text-amber-800 mb-1">Default Credentials</h4>
                  <p class="text-amber-700 text-sm m-0">
                    <strong>Username:</strong> <code>nvidia</code><br />
                    <strong>Password:</strong> <code>nvidia</code>
                  </p>
                </div>
              </div>
            </div>
          </div>
          
          <h3>Example</h3>
          
          <pre><code class="language-bash"># Connect to your Thor
ssh nvidia@192.168.1.100

# Enter password when prompted: nvidia</code></pre>
          
          <hr />
          
          <h2 id="verify">✅ Step 3: Verify Connection</h2>
          
          <p>Once connected, verify you're on a Jetson Thor:</p>
          
          <pre><code class="language-bash"># Check device info
cat /etc/nv_tegra_release

# Check GPU status
nvidia-smi</code></pre>
          
          <p>You should see information about the Blackwell GPU and L4T version.</p>
          
          <div class="not-prose my-8">
            <div class="bg-nvidia-green/5 border border-nvidia-green/20 rounded-xl p-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-nvidia-green rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-nvidia-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-0">You're Ready!</h4>
                  <p class="text-slate-600 m-0">Your Jetson Thor is connected. Continue to Lab 1 to start running LLMs and VLMs.</p>
                </div>
              </div>
            </div>
          </div>
          
        </div>
        
        <!-- Navigation -->
        <div class="mt-16 pt-8 border-t border-slate-200">
          <div class="flex justify-between items-center">
            <a href="/gtc26" class="flex items-center gap-2 text-slate-600 hover:text-nvidia-green transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Back to Workshop
            </a>
            <a href="/gtc26/intro-genai" class="flex items-center gap-2 bg-nvidia-green text-nvidia-black px-6 py-3 rounded-lg font-bold hover:bg-nvidia-green/90 transition-colors">
              Next: Lab 1 - Intro to GenAI
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 100px;
  }
</style>

